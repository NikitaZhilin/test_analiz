# Backend .env
# СКОПИРУЙТЕ ЭТОТ ФАЙЛ В .env И ИЗМЕНИТЕ ЗНАЧЕНИЯ

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/analyses

# Security - ГЕНЕРИРОВАТЬ СЛУЧАЙНУЮ СТРОКУ ДЛЯ PRODUCTION!
# Команда для генерации: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_RANDOM_STRING_32_CHARS_MINIMUM
ALGORITHM=HS256

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - указать точные домены
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Logging
LOG_LEVEL=INFO
