# Production environment variables
# Скопируйте этот файл в .env.prod и заполните реальными значениями

# Database
POSTGRES_USER=analyses_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD_$(openssl rand -hex 32)
POSTGRES_DB=analyses

# JWT Security
SECRET_KEY=CHANGE_ME_$(openssl rand -hex 32)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - укажите ваш IP или домен
CORS_ORIGINS=http://77.239.103.15

# Upload limit (MB)
MAX_UPLOAD_MB=20

# Logging
LOG_LEVEL=INFO
